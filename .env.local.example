NUONO_AI_ENABLED=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://aicodelink.top/v1
OPENAI_RESPONSES_PATH=/responses
OPENAI_DEFAULT_TEXT_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high
OPENAI_TIMEOUT_SECONDS=180
OPENAI_STORE_RESPONSES=false
OPENAI_INCLUDE_METADATA=false
NUONO_FILE_PARSE_AI_MODEL=gpt-5.4-mini
NUONO_FILE_PARSE_AI_REASONING_EFFORT=low
NUONO_FILE_PARSE_AI_MAX_OUTPUT_TOKENS=1000
NUONO_FILE_PARSE_AI_TIMEOUT_SECONDS=90

# Product selection source collection.
NUONO_PRODUCT_SELECTION_SOURCE_COLLECTION_SCHEDULER_ENABLED=true
NUONO_PRODUCT_SELECTION_AMAZON_CRAWLER_ENABLED=true
NUONO_PRODUCT_SELECTION_AMAZON_CRAWLER_URL=http://47.96.124.237/flask/crawl?channel={channel}&url={url}
NUONO_PRODUCT_SELECTION_AMAZON_CRAWLER_TIMEOUT_SECONDS=90
NUONO_PRODUCT_SELECTION_AMAZON_CRAWLER_FALLBACK_TO_PUBLIC_PAGE=false
NUONO_PRODUCT_SELECTION_SHEIN_RAPIDAPI_ENABLED=true
NUONO_PRODUCT_SELECTION_SHEIN_RAPIDAPI_KEY=
NUONO_PRODUCT_SELECTION_SHEIN_RAPIDAPI_CURRENCY=USD
NUONO_PRODUCT_SELECTION_SHEIN_RAPIDAPI_TIMEOUT_SECONDS=30
